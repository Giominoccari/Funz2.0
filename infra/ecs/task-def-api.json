{
  "family": "funghi-map-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/funghi-map-ecs-execution",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/funghi-map-api-task",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "ACCOUNT_ID.dkr.ecr.eu-south-1.amazonaws.com/funghi-map:latest",
      "essential": true,
      "command": ["serve", "--hostname", "0.0.0.0", "--port", "8080"],
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "LOG_LEVEL", "value": "info" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-south-1:ACCOUNT_ID:secret:funghi-map/database-url"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-south-1:ACCOUNT_ID:secret:funghi-map/redis-url"
        },
        {
          "name": "JWT_PRIVATE_KEY_FILE",
          "valueFrom": "arn:aws:secretsmanager:eu-south-1:ACCOUNT_ID:secret:funghi-map/jwt-private-key-file"
        },
        {
          "name": "STRIPE_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-south-1:ACCOUNT_ID:secret:funghi-map/stripe-secret-key"
        },
        {
          "name": "STRIPE_WEBHOOK_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-south-1:ACCOUNT_ID:secret:funghi-map/stripe-webhook-secret"
        },
        {
          "name": "ADMIN_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-south-1:ACCOUNT_ID:secret:funghi-map/admin-api-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/funghi-map-api",
          "awslogs-region": "eu-south-1",
          "awslogs-stream-prefix": "api"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      }
    }
  ]
}
